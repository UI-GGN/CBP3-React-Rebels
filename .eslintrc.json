{
  "overrides": [
    {
      "files": ["frontend/hatch-a-cab/*.js"],
      "env": {
        "browser": true,
        "es2021": true,
        "jest": true
      },
      "extends": ["react-app", "react-app/jest", "standard", "plugin:prettier/recommended"],
      "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
      },
      "plugins": ["react", "prettier"],
      "rules": {
        "prettier/prettier": "error"
      }
    }
  ]
}
